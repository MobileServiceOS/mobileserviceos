rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // True when the requesting user is the owner of {businessId} by convention
    // (we use businessId == uid for the owner's own business). This is what
    // makes the bootstrap flow work without a chicken-and-egg lookup: the
    // owner can create their own business doc, members doc, and settings doc
    // before users/{uid}.businessId has been read by any rule.
    function isOwnerByConvention(businessId) {
      return isSignedIn() && request.auth.uid == businessId;
    }

    // True when users/{uid}.businessId points at this business. Used to grant
    // access to additional members (non-owner team accounts).
    function hasUserBusinessLink(businessId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
    }

    // True when the requesting user has a members doc under this business.
    // Lets teammates be granted access by the owner without modifying their
    // users/{uid}.businessId field.
    function hasMemberDoc(businessId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/businesses/$(businessId)/members/$(request.auth.uid));
    }

    function canAccessBusiness(businessId) {
      return isOwnerByConvention(businessId)
        || hasUserBusinessLink(businessId)
        || hasMemberDoc(businessId);
    }

    // ── users/{uid} ─────────────────────────────────────────────
    // Each user owns their own user record. This is the first doc written
    // during signup bootstrap and must always be writable by its owner.
    match /users/{userId} {
      allow read, write: if isOwnUser(userId);
    }

    // ── businesses/{businessId} ────────────────────────────────
    // The owner (uid == businessId) can create their root business doc
    // unconditionally. Existing members can read/update. No one can delete
    // a business doc through these rules.
    match /businesses/{businessId} {
      allow read:   if canAccessBusiness(businessId);
      allow create: if isOwnerByConvention(businessId);
      allow update: if canAccessBusiness(businessId);
      allow delete: if false;

      // ── members/{uid} ──────────────────────────────────────
      // The owner can add anyone (typically only themselves on bootstrap).
      // A user may read their own membership record. The owner can update
      // or remove any member.
      match /members/{memberUid} {
        allow read:   if isOwnUser(memberUid) || isOwnerByConvention(businessId);
        allow create: if isOwnerByConvention(businessId);
        allow update: if isOwnerByConvention(businessId);
        allow delete: if isOwnerByConvention(businessId);
      }

      // ── settings/{settingId} ───────────────────────────────
      // settings/main is written during onboarding (before users/{uid}
      // bookkeeping completes), so the owner-by-convention path covers it.
      match /settings/{settingId} {
        allow read, write: if canAccessBusiness(businessId);
      }

      // ── jobs / inventory / expenses / invoices / operational_settings / etc ──
      // Wildcard for all other business-scoped subcollections.
      match /{collection}/{docId} {
        allow read, write: if canAccessBusiness(businessId);
      }

      // Deep nested fallback (e.g. settings/main/audit/X) — same access
      match /{collection}/{docId}/{rest=**} {
        allow read, write: if canAccessBusiness(businessId);
      }
    }

    // ── Default deny ────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
