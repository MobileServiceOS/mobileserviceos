# Production Firebase config — mobile-service-os project.
# Vite picks this up automatically during `npm run build` (and `vite build` in CI).
# These same values are also baked as fallbacks into src/lib/firebase.ts, so the
# build still works if this file is missing.
VITE_FIREBASE_API_KEY=AIzaSyDpe9pVejH1EFZmQYv04sgtZBoLxqM6lW0
VITE_FIREBASE_AUTH_DOMAIN=mobile-service-os.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=mobile-service-os
VITE_FIREBASE_STORAGE_BUCKET=mobile-service-os.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=77527561910
VITE_FIREBASE_APP_ID=1:77527561910:web:4a0c65c0203d403f4f5817

# AI proxy Worker (ai-proxy/). Public URL — gated by Firebase-token,
# origin, and task allowlists; the Anthropic key never leaves the Worker.
VITE_AI_PROXY_URL=https://mobileserviceos-ai-proxy.veyareid.workers.dev

# Stripe price IDs. NOT secrets — they're visible in any client-side
# checkout call (look at network DevTools when the Subscribe button
# fires). Safe to commit; the actual money flow is gated by Stripe's
# webhook signing secret + the Firebase Stripe Extension's own
# server-side validation. Read by SubscribeButton via
# import.meta.env.VITE_STRIPE_*.
VITE_STRIPE_PRO_PRICE_ID=price_1TSFYHB49ts9FRvl59AXOAoJ
VITE_STRIPE_CORE_PRICE_ID=price_1TSFXVB49ts9FRvlnSvOkJPu
