{
  "name": "mobile-service-os",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "description": "Mobile Service OS — white-label PWA for mobile tire & roadside businesses",
  "scripts": {
    "dev": "vite",
    "dev:emulator": "VITE_USE_FIREBASE_EMULATOR=1 vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync ios",
    "cap:open": "npx cap open ios",
    "ios": "npm run build && npx cap sync ios && npx cap open ios",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "for f in tests/*.test.ts; do echo \"\\n\\u25b6 $f\"; tsx \"$f\" || exit 1; done",
    "test:ui": "vitest run",
    "test:rules": "firebase emulators:exec --only firestore --project demo-msos \"vitest run --config vitest.rules.config.ts\"",
    "test:zettle-e2e": "firebase emulators:exec --only firestore --project demo-msos \"cd functions && npx tsx scripts/zettleE2E.ts\"",
    "deploy:rules": "firebase deploy --only firestore:rules,storage",
    "emulator:start": "firebase emulators:start --only auth,firestore,storage,functions --project mobile-service-os",
    "emulator:seed": "tsx scripts/seed-emulator.ts",
    "seed:appreview": "tsx scripts/seed-appreview.ts"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "firebase": "^12.14.0",
    "jspdf": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "firebase-tools": "^15.19.1",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.1",
    "vitest": "^2.1.9",
    "wrangler": "^4.94.0"
  }
}
