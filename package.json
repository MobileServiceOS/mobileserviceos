{
  "name": "mobile-service-os",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "description": "Mobile Service OS — white-label PWA for mobile tire & roadside businesses",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "for f in tests/*.test.ts; do echo \"\\n\\u25b6 $f\"; tsx \"$f\" || exit 1; done",
    "deploy:rules": "firebase deploy --only firestore:rules,storage"
  },
  "dependencies": {
    "firebase": "^10.13.0",
    "jspdf": "^2.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.1"
  }
}
