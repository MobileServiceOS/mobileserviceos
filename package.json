{
  "name": "mobile-service-os",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "description": "Mobile Service OS — white-label PWA for mobile tire & roadside businesses",
  "scripts": {
    "dev": "vite",
    "dev:emulator": "VITE_USE_FIREBASE_EMULATOR=1 vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "for f in tests/*.test.ts; do echo \"\\n\\u25b6 $f\"; tsx \"$f\" || exit 1; done",
    "test:ui": "vitest run",
    "deploy:rules": "firebase deploy --only firestore:rules,storage",
    "emulator:start": "firebase emulators:start --only auth,firestore,storage,functions --project mobile-service-os",
    "emulator:seed": "tsx scripts/seed-emulator.ts"
  },
  "dependencies": {
    "firebase": "^12.14.0",
    "jspdf": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.1",
    "vitest": "^2.1.9",
    "wrangler": "^4.94.0"
  }
}
