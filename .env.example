# Copy to .env.local for local development. Production values live in .env.production.
# Source: Firebase Console → Project Settings → General → Your apps → Web app → Config.
VITE_FIREBASE_API_KEY=AIzaSyDpe9pVejH1EFZmQYv04sgtZBoLxqM6lW0
VITE_FIREBASE_AUTH_DOMAIN=mobile-service-os.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=mobile-service-os
VITE_FIREBASE_STORAGE_BUCKET=mobile-service-os.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=77527561910
VITE_FIREBASE_APP_ID=1:77527561910:web:4a0c65c0203d403f4f5817

# Override Vite base path for non-GitHub-Pages deploys (default: /mobileserviceos/)
# VITE_BASE_PATH=/

# AI proxy Worker URL. Leave empty to disable AI features (the app
# works fine without them). Deploy ai-proxy/ and paste its URL here.
# See ai-proxy/README.md.
VITE_AI_PROXY_URL=

# ─────────────────────────────────────────────────────────────────
# AI Ops layer (docs/ai-ops-layer.md)
#
# The Anthropic API key is a SERVER secret for the `aiOps` Cloud
# Function. It is NOT a VITE_ variable — VITE_ vars are inlined into the
# client bundle and would leak the key. Configure it on the server only:
#
#   firebase functions:secrets:set ANTHROPIC_API_KEY
#
# Optional model override (server env var, allow-listed in aiOps.ts;
# defaults to claude-sonnet-4-6):
#
#   firebase functions:secrets:set ANTHROPIC_MODEL   # or set as env
#
# Until ANTHROPIC_API_KEY is set, the loops fail cleanly with
# AI_NOT_CONFIGURED (the rest of the app is unaffected).
# ─────────────────────────────────────────────────────────────────

# Stripe price IDs (Stripe Dashboard → Products → [product] →
# Pricing → API ID). NOT secrets — visible in any client-side
# checkout call. Leave empty to disable Subscribe buttons.
VITE_STRIPE_PRO_PRICE_ID=
VITE_STRIPE_CORE_PRICE_ID=
