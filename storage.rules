rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // Owner-by-convention: businessId == auth.uid. Used during bootstrap so
    // logo uploads work BEFORE users/{uid}.businessId is written. This is
    // the same model the Firestore rules use — keep them aligned.
    function isOwnerByConvention(businessId) {
      return isSignedIn() && request.auth.uid == businessId;
    }

    // SECURITY (2026-07 audit, C-1): there is intentionally NO
    // `hasUserBusinessLink` here. Deriving access from
    // users/{uid}.businessId is a CROSS-TENANT LEAK — that doc is fully
    // client-writable (firestore.rules: users/{uid} allow write if
    // isOwnUser, no value validation), so any authenticated user could
    // self-set businessId to a victim's id and read/write that tenant's
    // private receipts and files. Access is granted ONLY by the two
    // UNFORGEABLE signals below, mirroring the Firestore rules' model.
    // Do NOT re-introduce a users-doc check here.

    // Member doc check — the unforgeable authority for teammate access. An
    // owner/admin/technician the owner added has a members/{uid} doc, which
    // only the owner/admin can create (enforced in firestore.rules).
    function hasMemberDoc(businessId) {
      return isSignedIn()
        && firestore.exists(/databases/(default)/documents/businesses/$(businessId)/members/$(request.auth.uid));
    }

    function canAccessBusiness(businessId) {
      return isOwnerByConvention(businessId)
        || hasMemberDoc(businessId);
    }

    // Image content-type gate. Reused by all image-writing paths below.
    function isAllowedImage() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|jpg|webp)');
    }

    // ── Branding (logo) ──────────────────────────────────
    // Logos are read by anyone (so they can render on shareable invoices)
    // but only the owner/members can write.
    match /businesses/{businessId}/branding/{file=**} {
      allow read: if true;
      allow write: if canAccessBusiness(businessId) && isAllowedImage();
    }

    // ── Receipts (expense/job receipts) ──────────────────
    // Private — only the business itself can read its own receipts.
    match /businesses/{businessId}/receipts/{file=**} {
      allow read, write: if canAccessBusiness(businessId)
                            && (request.resource == null || request.resource.size < 8 * 1024 * 1024);
    }

    // Any other business-scoped path — same access model, same size cap.
    // The size cap is required (2026-06-05 audit): without it any member
    // (incl. a technician) could upload unbounded / arbitrary-type files
    // here, enabling storage-cost abuse and hosting arbitrary content on
    // a project-domain URL. `request.resource == null` permits deletes.
    match /businesses/{businessId}/{path=**} {
      allow read: if canAccessBusiness(businessId);
      allow write: if canAccessBusiness(businessId)
                      && (request.resource == null || request.resource.size < 8 * 1024 * 1024);
    }

    // Default deny everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
