rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: get the businessId for the requesting user
    function userBusinessId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMemberOfBusiness(businessId) {
      return isSignedIn() && userBusinessId() == businessId;
    }

    // Each user can only read/write their own user record
    match /users/{userId} {
      allow read, write: if isOwnUser(userId);
    }

    // ─────────────────────────────────────────────────────────────────
    // Invites — top-level collection, token-keyed.
    // Schema: invites/{token} where token is a 128-bit random string.
    //
    // States: pending → accepted | revoked | expired
    //
    // Permissions:
    //   - CREATE: owner/admin of the target business may create an
    //             invite for THEIR business with role admin|technician
    //             (never owner), status='pending', and a future
    //             expiresAt. The invitedBy field must be the creator.
    //
    //   - READ:   anyone signed-in who knows the token (the link IS
    //             the secret). Pragmatic and matches the link-as-key
    //             threat model.
    //
    //   - UPDATE to status='accepted': only by the user whose auth
    //             token email matches the invite's email field, and
    //             only when the existing status='pending' AND the
    //             invite hasn't expired. Their uid is recorded.
    //
    //   - UPDATE to status='revoked': owner/admin of the inviting
    //             business may revoke their own invite. Only allowed
    //             when status='pending'.
    //
    //   - UPDATE to status='expired': anyone signed-in can mark an
    //             expired pending invite as expired. This is a no-harm
    //             cleanup transition the invitee or owner may trigger
    //             on read.
    //
    //   - DELETE: not allowed — keep audit trail. Use revoke instead.
    // ─────────────────────────────────────────────────────────────────
    match /invites/{token} {
      // CREATE — only by owner/admin of the target business.
      // We validate against the requesting user's businessId from
      // their /users/{uid} doc. Role limited to admin|technician.
      allow create: if isSignedIn()
        && request.resource.data.businessId == userBusinessId()
        && request.resource.data.invitedBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && (request.resource.data.role == 'admin' || request.resource.data.role == 'technician')
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.token == token
        && request.resource.data.expiresAt is string;

      // READ — publicly readable. The token IS the secret (same threat
      // model as a Google Doc "anyone with the link" share). Requiring
      // auth to read would break the v1 onboarding flow: invitee taps
      // link from iMessage → Safari opens fresh, NOT signed in → if
      // read requires auth, the InviteAccept page can't show "Join
      // Wheel Rush as a technician" until after sign-in, which is the
      // wrong order. Acceptance still requires auth + email match
      // (enforced in the update rule below) so this read-only access
      // can't be used to escalate privilege — only to view the
      // business name, role, and inviter to decide whether to accept.
      allow read: if true;

      // UPDATE — three permitted transitions, each with its own rule.
      //
      // Note on expiresAt: it's stored as an ISO string for portability
      // (Firestore can sort/query strings, and the client uses Date.parse
      // for comparisons). Firestore rules don't have an ISO-to-millis
      // parser, so expiry is enforced at the application level
      // (acceptInvite throws on expired invites). The rule still
      // prevents abuse via the email-match + status-transition guards
      // below — an attacker can't accept someone else's invite, and
      // an "expired but still accepted" scenario only succeeds if the
      // client deliberately bypasses its own check.
      allow update: if isSignedIn() && (
        // (a) Accept: invitee transitions pending → accepted.
        //     Email-match + status was pending + new acceptedByUid is
        //     the requesting user.
        (
          resource.data.status == 'pending'
          && request.resource.data.status == 'accepted'
          && resource.data.email == request.auth.token.email.lower()
          && request.resource.data.acceptedByUid == request.auth.uid
        )
        ||
        // (b) Revoke: owner/admin of the inviting business flips
        //     pending → revoked.
        (
          resource.data.status == 'pending'
          && request.resource.data.status == 'revoked'
          && resource.data.businessId == userBusinessId()
        )
        ||
        // (c) Expire: lazy expiry transition. Anyone signed in can
        //     mark a pending invite expired — it's a no-harm cleanup.
        (
          resource.data.status == 'pending'
          && request.resource.data.status == 'expired'
        )
      );

      // No deletes — keep audit trail.
      allow delete: if false;
    }

    // All business data is scoped: only members of that business can read.
    // For writes, we additionally restrict sensitive paths (settings,
    // operational_settings, members, expenses) to owner/admin roles only —
    // technicians can read everything in the business but can't write to
    // business-config docs. Jobs/inventory remain writable by any member
    // (technicians need to log jobs and adjust inventory mid-job).
    function memberRole(businessId) {
      return get(/databases/$(database)/documents/businesses/$(businessId)/members/$(request.auth.uid)).data.role;
    }
    function isOwnerOrAdmin(businessId) {
      return isMemberOfBusiness(businessId) && (
        memberRole(businessId) == 'owner' || memberRole(businessId) == 'admin'
      );
    }

    match /businesses/{businessId} {
      allow read: if isMemberOfBusiness(businessId);
      // Business root doc — owner/admin only writes. Convention-owner
      // fallback: when there's no members doc yet (legacy owner who
      // bootstrapped before the members collection existed), the
      // owner's uid equals businessId, and they can still write.
      allow write: if isOwnerOrAdmin(businessId) || request.auth.uid == businessId;

      // Sensitive config — owner/admin only writes.
      // Reads stay member-scoped for the rest of the app to function.
      //
      // EXEMPTION FIELDS LOCKDOWN:
      //   The following fields on settings/main are NEVER writable from
      //   the client, regardless of role. They control lifetime Pro
      //   access and must only be modified by Admin SDK (Cloud Functions
      //   running with admin privilege):
      //
      //     - billingExempt
      //     - subscriptionOverride
      //     - exemptionGrantedAt
      //     - exemptionGrantedBy
      //     - exemptionReason
      //
      //   Why lock these: a client write that flips `billingExempt: true`
      //   would grant the user permanent Pro access without paying.
      //   The Wheel Rush founder document already has these set in
      //   Firestore via prior grant; no client code needs to write them
      //   ever again.
      //
      //   The helper below returns true ONLY when the incoming write
      //   does NOT modify any of the locked fields (either omits them,
      //   or sets them to the same value already in the document).
      function exemptionFieldsUnchanged(beforeData, afterData) {
        return (
          (!('billingExempt' in afterData) || beforeData.billingExempt == afterData.billingExempt)
          && (!('subscriptionOverride' in afterData) || beforeData.subscriptionOverride == afterData.subscriptionOverride)
          && (!('exemptionGrantedAt' in afterData) || beforeData.exemptionGrantedAt == afterData.exemptionGrantedAt)
          && (!('exemptionGrantedBy' in afterData) || beforeData.exemptionGrantedBy == afterData.exemptionGrantedBy)
          && (!('exemptionReason' in afterData) || beforeData.exemptionReason == afterData.exemptionReason)
        );
      }
      // For CREATE on settings/main: deny ALL exemption fields entirely
      // (a brand new settings doc must never start exempt — only Admin
      // SDK can later flip these via a separate write path).
      function noExemptionFieldsOnCreate(afterData) {
        return (
          !('billingExempt' in afterData)
          && !('subscriptionOverride' in afterData)
          && !('exemptionGrantedAt' in afterData)
          && !('exemptionGrantedBy' in afterData)
          && !('exemptionReason' in afterData)
        );
      }

      match /settings/{docId} {
        allow read: if isMemberOfBusiness(businessId);
        // CREATE: owner/admin only, AND must not include any exemption
        // field (would let a fresh signup self-grant Pro forever).
        allow create: if (isOwnerOrAdmin(businessId) || request.auth.uid == businessId)
          && noExemptionFieldsOnCreate(request.resource.data);
        // UPDATE: owner/admin only, AND every locked exemption field
        // must match the existing value (no client can flip them).
        allow update: if (isOwnerOrAdmin(businessId) || request.auth.uid == businessId)
          && exemptionFieldsUnchanged(resource.data, request.resource.data);
        // DELETE: owner/admin only. Rare in practice; settings is
        // typically reset by overwriting, not deleting.
        allow delete: if isOwnerOrAdmin(businessId) || request.auth.uid == businessId;
      }
      match /operational_settings/{docId} {
        allow read: if isMemberOfBusiness(businessId);
        allow write: if isOwnerOrAdmin(businessId) || request.auth.uid == businessId;
      }
      match /expenses/{docId} {
        allow read: if isMemberOfBusiness(businessId);
        allow write: if isOwnerOrAdmin(businessId) || request.auth.uid == businessId;
      }
      // Members collection — owner/admin only writes for role/invite
      // management. EXCEPTION: a user can write their OWN member doc
      // (matched by memberId == auth.uid) to support self-deletion /
      // "leave team" flows. The user can only mark themselves; they
      // can't escalate to owner because rules don't validate fields,
      // but the application-level UI controls what fields get
      // written here (status: 'left', leftAt: timestamp).
      match /members/{memberId} {
        allow read: if isMemberOfBusiness(businessId);
        allow write: if isOwnerOrAdmin(businessId)
          || request.auth.uid == businessId
          || request.auth.uid == memberId;
      }

      // Meta collection — deletion requests and other admin signals.
      // Any signed-in member can write their own deletion request.
      // Owner/admin can also write meta docs for purge tracking.
      match /meta/{docId} {
        allow read: if isMemberOfBusiness(businessId);
        allow write: if isMemberOfBusiness(businessId);
      }

      // Everything else under the business (jobs, inventory, customers,
      // technicians, products) — any member can read. Writes default to
      // member-level too (technicians need to log jobs and consume
      // inventory mid-job). Sensitive paths above OVERRIDE this with
      // role-restricted writes via more-specific match blocks. Note:
      // Firestore rules union allow conditions across matching paths,
      // so this wildcard must NOT be more permissive than the specific
      // rules for sensitive collections. Since this rule only matches
      // documents NOT covered by the specific matches above when read
      // alone, but Firestore evaluates ALL matching rules, we keep
      // this aligned with the most-permissive intent for non-sensitive
      // paths only.
      //
      // To prevent the wildcard from re-enabling writes on sensitive
      // paths, the specific match blocks above use the same `read:
      // isMemberOfBusiness` for reads and restrict writes to
      // owner/admin. Because Firestore uses an OR across matching
      // rules, the wildcard write would still grant access to
      // settings/operational_settings/expenses/members. To prevent
      // this, we make the wildcard READ-only and let the per-path
      // rules above handle writes explicitly.
      match /{document=**} {
        allow read: if isMemberOfBusiness(businessId);
      }
      // Per-collection write rules for non-sensitive paths.
      // Jobs + inventory + customers + technicians = all members write.
      match /jobs/{docId} {
        allow write: if isMemberOfBusiness(businessId);
      }
      match /inventory/{docId} {
        allow write: if isMemberOfBusiness(businessId);
      }
      match /customers/{docId} {
        allow write: if isMemberOfBusiness(businessId);
      }
      match /technicians/{docId} {
        allow write: if isMemberOfBusiness(businessId);
      }
    }

    // ─────────────────────────────────────────────────────────────────
    // STRIPE FIREBASE EXTENSION COLLECTIONS
    //
    // The "Run Subscription Payments with Stripe" extension writes to
    // these top-level collections. The extension itself uses Admin SDK
    // and bypasses these rules — but the client app MUST be able to:
    //
    //   1. WRITE checkout_sessions and portal_links sub-docs (these are
    //      how the client requests a checkout URL — the extension reads
    //      these writes and fills in the URL).
    //   2. READ its own customer doc + subscriptions + payments + the
    //      checkout_session it just wrote (to receive the resolved URL).
    //   3. READ products + prices + tax_rates publicly (these are the
    //      catalog the client reads to display plan options if it ever
    //      needs to).
    //
    // Strict isolation: a user can only access their OWN /customers/{uid}
    // sub-tree (uid matches request.auth.uid). No cross-user reads.
    // ─────────────────────────────────────────────────────────────────

    match /customers/{uid} {
      // A user can read their own Stripe customer doc.
      allow read: if isSignedIn() && request.auth.uid == uid;
      // No client writes — Stripe extension creates this via Admin SDK.

      match /checkout_sessions/{id} {
        // Client creates the request doc; extension fills in `url`.
        // Client reads the doc to learn the URL.
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }

      match /subscriptions/{id} {
        // Read-only: the extension mirrors subscription state here.
        allow read: if isSignedIn() && request.auth.uid == uid;
        // No client writes.

        match /{path=**} {
          allow read: if isSignedIn() && request.auth.uid == uid;
        }
      }

      match /payments/{id} {
        // Read-only: extension writes invoice/payment history here.
        allow read: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // Stripe products + prices — public catalog read.
    // These are mirrored from Stripe by the extension. Any signed-in
    // user can read them so plan selection UIs render.
    match /products/{productId} {
      allow read: if isSignedIn();
      match /prices/{priceId} {
        allow read: if isSignedIn();
      }
      match /tax_rates/{taxRateId} {
        allow read: if isSignedIn();
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
