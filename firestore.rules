rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: get the businessId for the requesting user
    function userBusinessId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ───────────────────────────────────────────────────────────
    //  MEMBERSHIP — members doc is the source of truth
    //  ───────────────────────────────────────────────────────────
    //  A user belongs to a business when a members/{uid} doc exists
    //  for them under that business. That doc is unforgeable: writing
    //  it is itself rules-protected (only an existing owner/admin of
    //  the business, or the documented bootstrap path, can create it).
    //
    //  LEGACY FALLBACK: every business that predates the multi-
    //  business work was bootstrapped with businessId == owner uid and
    //  may have NO members doc. The `request.auth.uid == businessId`
    //  branch keeps those owners fully recognized with zero migration.
    //
    //  The `ownedBusinesses` array on the user doc is NEVER consulted
    //  here — it drives the switcher UI only. Security is enforced
    //  solely by the unforgeable members doc, so a tampered array
    //  cannot grant access to a business the user is not a member of.

    // True when a members/{uid} doc exists for the requesting user
    // under the given business.
    function memberDocExists(businessId) {
      return exists(/databases/$(database)/documents/businesses/$(businessId)/members/$(request.auth.uid));
    }

    function isMemberOfBusiness(businessId) {
      return isSignedIn() && (
        memberDocExists(businessId) ||
        request.auth.uid == businessId   // legacy convention-owner
      );
    }

    // Each user can only read/write their own user record
    match /users/{userId} {
      allow read, write: if isOwnUser(userId);
    }

    // ─────────────────────────────────────────────────────────────────
    // errorLogs — per-user append-only error monitoring sink
    // (src/lib/errorMonitor.ts).
    //
    // Path: errorLogs/{uid}/entries/{entryId}
    //
    // P1 audit follow-up (2026-06-03): writes now go to a per-uid
    // subcollection rather than the flat top-level collection. Three
    // wins:
    //   1. Attribution — every entry is namespaced under its writer's
    //      uid, so any abuse pattern is traceable to a specific user
    //      without an extra `uid` field on the entry.
    //   2. Tractable cleanup — a Cloud Function can purge a single
    //      user's entries by deleting their parent doc; the prior
    //      flat collection forced a collectionGroup scan + filter.
    //   3. Self-write only — the rule below enforces `auth.uid == uid`
    //      so one compromised session cannot pollute another user's
    //      bucket. The prior flat rule let any signed-in user write
    //      anywhere in the collection.
    //
    // Legacy top-level errorLogs/{logId} writes are no longer
    // permitted (allow create: if false on the legacy path below).
    // Existing pre-restructure docs remain readable from the Firebase
    // Console / admin tools; no migration needed (they're not
    // referenced by any client code, only triaged manually).
    // ─────────────────────────────────────────────────────────────────
    match /errorLogs/{uid} {
      // The parent doc is never written from the client — only the
      // subcollection is. Reads stay blocked so a compromised client
      // can't enumerate users by checking which uid buckets exist.
      allow read, write: if false;

      match /entries/{entryId} {
        // Schema + size cap on each entry.
        // 8 KiB total leaves room for message (1KB) + stack (4KB) +
        // the usual ~3KB of context / headers / metadata.
        allow create: if request.auth != null
          && request.auth.uid == uid
          && request.resource.size() < 8192
          && request.resource.data.keys().hasAll(['ts', 'level', 'message', 'appVersion'])
          && request.resource.data.level in ['error', 'warning', 'info']
          && request.resource.data.message is string
          && request.resource.data.message.size() <= 1000
          && request.resource.data.ts is string
          && request.resource.data.appVersion is string;
        allow read, update, delete: if false;
      }
    }

    // Legacy top-level errorLogs/{logId} path — closed for writes
    // post-restructure. Pre-existing docs remain readable from the
    // Firebase Console (admin SDK bypasses rules); only client writes
    // are blocked.
    match /errorLogs/{logId} {
      allow create, read, update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────────
    // analytics/{YYYY-MM-DD} — first-party, AGGREGATE-ONLY product
    // counters (src/lib/analytics.ts). No PII, no per-user linkage: each
    // doc is just { date, counts: { <event>: N }, updatedAt } incremented
    // by signed-in clients. Reads stay closed so the counts aren't
    // enumerable by clients — triage from the Firebase Console (admin SDK
    // bypasses rules). Writes are constrained to the expected shape + a
    // size cap so the doc can't be turned into arbitrary storage.
    // ─────────────────────────────────────────────────────────────────
    match /analytics/{day} {
      allow read: if false;
      allow create, update: if request.auth != null
        && request.resource.size() < 20000
        && request.resource.data.keys().hasOnly(['date', 'counts', 'updatedAt'])
        && request.resource.data.date is string
        && request.resource.data.counts is map;
      allow delete: if false;
    }

    // ─────────────────────────────────────────────────────────────────
    // Invites — top-level collection, token-keyed.
    // Schema: invites/{token} where token is a 128-bit random string.
    //
    // States: pending → accepted | revoked | expired
    //
    // Permissions:
    //   - CREATE: owner/admin of the target business may create an
    //             invite for THEIR business with role admin|technician
    //             (never owner), status='pending', and a future
    //             expiresAt. The invitedBy field must be the creator.
    //
    //   - READ:   anyone signed-in who knows the token (the link IS
    //             the secret). Pragmatic and matches the link-as-key
    //             threat model.
    //
    //   - UPDATE to status='accepted': only by the user whose auth
    //             token email matches the invite's email field, and
    //             only when the existing status='pending' AND the
    //             invite hasn't expired. Their uid is recorded.
    //
    //   - UPDATE to status='revoked': owner/admin of the inviting
    //             business may revoke their own invite. Only allowed
    //             when status='pending'.
    //
    //   - UPDATE to status='expired': anyone signed-in can mark an
    //             expired pending invite as expired. This is a no-harm
    //             cleanup transition the invitee or owner may trigger
    //             on read.
    //
    //   - DELETE: not allowed — keep audit trail. Use revoke instead.
    // ─────────────────────────────────────────────────────────────────
    match /invites/{token} {
      // CREATE — only by owner/admin of the target business.
      // We validate against the requesting user's businessId from
      // their /users/{uid} doc. Role limited to admin|technician.
      //
      // Hotfix (2026-05-31, audit P1): previous rule only checked
      // that the invite's businessId matched the inviter's user-doc
      // businessId. A technician (whose users/{uid}.businessId
      // legitimately points at their team's business) could create
      // an invite with role:'admin' for an email they control,
      // accept it from a second tab, and self-promote to admin.
      // Added the isOwnerOrAdmin(userBusinessId()) guard to close
      // the path.
      allow create: if isSignedIn()
        && request.resource.data.businessId == userBusinessId()
        && isOwnerOrAdmin(userBusinessId())
        && request.resource.data.invitedBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && (request.resource.data.role == 'admin' || request.resource.data.role == 'technician')
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.token == token
        && request.resource.data.expiresAt is string;

      // READ — publicly readable. The token IS the secret (same threat
      // model as a Google Doc "anyone with the link" share). Requiring
      // auth to read would break the v1 onboarding flow: invitee taps
      // link from iMessage → Safari opens fresh, NOT signed in → if
      // read requires auth, the InviteAccept page can't show "Join
      // Wheel Rush as a technician" until after sign-in, which is the
      // wrong order. Acceptance still requires auth + email match
      // (enforced in the update rule below) so this read-only access
      // can't be used to escalate privilege — only to view the
      // business name, role, and inviter to decide whether to accept.
      allow read: if true;

      // UPDATE — three permitted transitions, each with its own rule.
      //
      // Note on expiresAt: it's stored as an ISO string for portability
      // (Firestore can sort/query strings, and the client uses Date.parse
      // for comparisons). Firestore rules don't have an ISO-to-millis
      // parser, so expiry is enforced at the application level
      // (acceptInvite throws on expired invites). The rule still
      // prevents abuse via the email-match + status-transition guards
      // below — an attacker can't accept someone else's invite, and
      // an "expired but still accepted" scenario only succeeds if the
      // client deliberately bypasses its own check.
      allow update: if isSignedIn() && (
        // (a) Accept: invitee transitions pending → accepted.
        //     Email-match + status was pending + new acceptedByUid is
        //     the requesting user.
        (
          resource.data.status == 'pending'
          && request.resource.data.status == 'accepted'
          && resource.data.email == request.auth.token.email.lower()
          && request.resource.data.acceptedByUid == request.auth.uid
        )
        ||
        // (b) Revoke: owner/admin of the inviting business flips
        //     pending → revoked.
        //
        // P1 audit fix (2026-06-03): previously this clause only
        // checked `resource.data.businessId == userBusinessId()`,
        // which trusts a client-writable field on the user doc. A
        // malicious user could self-set their users/{uid}.businessId
        // to a victim's businessId, then "revoke" pending invites,
        // DoS'ing legitimate onboarding flows. Replaced the spoofable
        // userBusinessId() check with isOwnerOrAdmin against the
        // INVITE's businessId — server-authoritative via the members
        // doc which is unforgeable from the client.
        (
          resource.data.status == 'pending'
          && request.resource.data.status == 'revoked'
          && isOwnerOrAdmin(resource.data.businessId)
        )
        ||
        // (c) Expire: lazy expiry transition. Anyone signed in can
        //     mark a pending invite expired — it's a no-harm cleanup.
        (
          resource.data.status == 'pending'
          && request.resource.data.status == 'expired'
        )
      );

      // No deletes — keep audit trail.
      allow delete: if false;
    }

    // All business data is scoped: only members of that business can read.
    // For writes, we additionally restrict sensitive paths (settings,
    // operational_settings, members, expenses) to owner/admin roles only —
    // technicians can read everything in the business but can't write to
    // business-config docs. Jobs/inventory remain writable by any member
    // (technicians need to log jobs and adjust inventory mid-job).
    function memberRole(businessId) {
      return get(/databases/$(database)/documents/businesses/$(businessId)/members/$(request.auth.uid)).data.role;
    }

    // 1b: the ownerUid stamped on a business's settings/main doc at
    // creation. Returns '' when the settings doc does not exist or has
    // no ownerUid field (legacy businesses) — never errors, so the
    // members-write self-enroll clause simply fails closed for any
    // business that was not created via the 1b add-business flow.
    //
    // Uses getAfter()/existsAfter() — the POST-commit state of the
    // transaction. This is required because the add-business flow
    // writes settings/main and members/{uid} in the SAME atomic
    // writeBatch: a plain get() would see pre-batch state (no
    // settings doc yet) and wrongly deny the member write. getAfter()
    // sees the settings doc the same batch is creating. For any write
    // OUTSIDE a batch, getAfter() equals get() — the post-commit
    // state of an already-committed doc is just its current state —
    // so this is correct in every case, not only the batch case.
    function businessOwnerUid(businessId) {
      return existsAfter(/databases/$(database)/documents/businesses/$(businessId)/settings/main)
        ? getAfter(/databases/$(database)/documents/businesses/$(businessId)/settings/main).data.get('ownerUid', '')
        : '';
    }
    function isOwnerOrAdmin(businessId) {
      return isSignedIn() && (
        // Legacy convention-owner: no members doc, uid == businessId.
        // Such an owner is always treated as owner of their business.
        request.auth.uid == businessId ||
        // Normal path: a members doc exists and grants owner/admin.
        (memberDocExists(businessId) &&
          (memberRole(businessId) == 'owner' || memberRole(businessId) == 'admin'))
      );
    }

    match /businesses/{businessId} {
      allow read: if isMemberOfBusiness(businessId);
      // Business root doc — owner/admin only writes. Convention-owner
      // fallback: when there's no members doc yet (legacy owner who
      // bootstrapped before the members collection existed), the
      // owner's uid equals businessId, and they can still write.
      allow write: if isOwnerOrAdmin(businessId) || request.auth.uid == businessId;

      // Sensitive config — owner/admin only writes.
      // Reads stay member-scoped for the rest of the app to function.
      //
      // EXEMPTION FIELDS LOCKDOWN:
      //   The following fields on settings/main are NEVER writable from
      //   the client, regardless of role. They control lifetime Pro
      //   access and must only be modified by Admin SDK (Cloud Functions
      //   running with admin privilege):
      //
      //     - billingExempt
      //     - subscriptionOverride
      //     - exemptionGrantedAt
      //     - exemptionGrantedBy
      //     - exemptionReason
      //
      //   Why lock these: a client write that flips `billingExempt: true`
      //   would grant the user permanent Pro access without paying.
      //   The Wheel Rush founder document already has these set in
      //   Firestore via prior grant; no client code needs to write them
      //   ever again.
      //
      //   The helper below returns true ONLY when the incoming write
      //   does NOT modify any of the locked fields (either omits them,
      //   or sets them to the same value already in the document).
      function exemptionFieldsUnchanged(beforeData, afterData) {
        return (
          (!('billingExempt' in afterData) || beforeData.billingExempt == afterData.billingExempt)
          && (!('subscriptionOverride' in afterData) || beforeData.subscriptionOverride == afterData.subscriptionOverride)
          && (!('exemptionGrantedAt' in afterData) || beforeData.exemptionGrantedAt == afterData.exemptionGrantedAt)
          && (!('exemptionGrantedBy' in afterData) || beforeData.exemptionGrantedBy == afterData.exemptionGrantedBy)
          && (!('exemptionReason' in afterData) || beforeData.exemptionReason == afterData.exemptionReason)
        );
      }
      // For CREATE on settings/main: deny ALL exemption fields entirely
      // (a brand new settings doc must never start exempt — only Admin
      // SDK can later flip these via a separate write path).
      function noExemptionFieldsOnCreate(afterData) {
        return (
          !('billingExempt' in afterData)
          && !('subscriptionOverride' in afterData)
          && !('exemptionGrantedAt' in afterData)
          && !('exemptionGrantedBy' in afterData)
          && !('exemptionReason' in afterData)
        );
      }

      // For UPDATE on settings/main: deny ALL referral-reward fields
      // entirely. A client write must never modify these — only the
      // server (Cloud Function via Admin SDK) writes them.
      function referralRewardFieldsUnchanged(beforeData, afterData) {
        return (
          (!('referralCreditsMonths' in afterData) || beforeData.referralCreditsMonths == afterData.referralCreditsMonths)
          && (!('totalSuccessfulReferrals' in afterData) || beforeData.totalSuccessfulReferrals == afterData.totalSuccessfulReferrals)
          // referredBy + referredByCode + referralDocId are set ONCE
          // at create-time (or shortly after by the same client during
          // onboarding). After they have a value, they cannot change.
          && (!('referredBy' in afterData) || !('referredBy' in beforeData) || beforeData.referredBy == null || beforeData.referredBy == afterData.referredBy)
          && (!('referredByCode' in afterData) || !('referredByCode' in beforeData) || beforeData.referredByCode == null || beforeData.referredByCode == afterData.referredByCode)
          && (!('referralDocId' in afterData) || !('referralDocId' in beforeData) || beforeData.referralDocId == null || beforeData.referralDocId == afterData.referralDocId)
        );
      }
      // For CREATE: client can set referredBy/referredByCode/referralDocId
      // (signup capture) but never the reward fields.
      function noReferralRewardFieldsOnCreate(afterData) {
        return (
          !('referralCreditsMonths' in afterData)
          && !('totalSuccessfulReferrals' in afterData)
        );
      }

      match /settings/{docId} {
        allow read: if isMemberOfBusiness(businessId);
        // CREATE: owner/admin only, AND must not include any exemption
        // field (would let a fresh signup self-grant Pro forever) NOR
        // any reward-tally field (would let a fresh signup pre-credit).
        //
        // MULTI-BUSINESS (1b): a brand-new business created via the
        // add-business flow has businessId != creator uid, so the
        // `isOwnerOrAdmin || uid==businessId` branch alone would block
        // it. We additionally allow create when the doc stamps
        // `ownerUid` equal to the creator's own uid — this is what
        // makes the business provably theirs. The stamp can ONLY be
        // the creator's uid (request.resource.data.ownerUid ==
        // request.auth.uid), so a user cannot create a business owned
        // by someone else. The members-write rule below then keys off
        // this same ownerUid stamp.
        allow create: if (
            isOwnerOrAdmin(businessId)
            || request.auth.uid == businessId
            || request.resource.data.get('ownerUid', '') == request.auth.uid
          )
          && noExemptionFieldsOnCreate(request.resource.data)
          && noReferralRewardFieldsOnCreate(request.resource.data);
        // UPDATE: owner/admin only, AND every locked exemption field
        // AND every locked reward field must match the existing value.
        //
        // ownerUid immutability: once a settings doc HAS an ownerUid,
        // it can never change. Legacy tire settings docs have NO
        // ownerUid field at all — for them this check must be a
        // no-op, never a block. The clause below holds in both cases:
        //   - legacy doc (no ownerUid): both sides absent -> passes,
        //     and an update may not introduce a foreign ownerUid
        //     because adding one would require it to equal the
        //     (absent) existing value.
        //   - 1b doc (has ownerUid): the value must be carried
        //     through unchanged.
        allow update: if (isOwnerOrAdmin(businessId) || request.auth.uid == businessId)
          && exemptionFieldsUnchanged(resource.data, request.resource.data)
          && referralRewardFieldsUnchanged(resource.data, request.resource.data)
          && (
            request.resource.data.get('ownerUid', '') == resource.data.get('ownerUid', '')
          );
        // DELETE: owner/admin only. Rare in practice; settings is
        // typically reset by overwriting, not deleting.
        allow delete: if isOwnerOrAdmin(businessId) || request.auth.uid == businessId;
      }
      match /operational_settings/{docId} {
        allow read: if isMemberOfBusiness(businessId);
        allow write: if isOwnerOrAdmin(businessId) || request.auth.uid == businessId;
      }

      // NOTE: Zettle sensitive collections do NOT live here. The
      // `businesses/{businessId}/{document=**}` wildcard below grants
      // READ to every member, so an owner/admin-only rule placed here
      // would be a no-op (rules are a permissive union — a narrow rule
      // can't restrict what the wildcard already allows; verified by
      // tests/rules/firestore.rules.test.ts). Sensitive data must live in
      // a TOP-LEVEL collection outside this member-readable subtree.

      match /expenses/{docId} {
        allow read: if isMemberOfBusiness(businessId);
        allow write: if isOwnerOrAdmin(businessId) || request.auth.uid == businessId;
      }
      // Members collection — role-transition matrix enforced server-side.
      match /members/{memberId} {
        allow read: if isMemberOfBusiness(businessId);
        // WRITE paths (owner-only role transitions are enforced
        // server-side; last-owner protection is client-side):
        //
        //  1. Convention-owner (uid == businessId) — pre-multi-business
        //     bootstrap path. Unchanged.
        //
        //  2. Self-enroll into a business YOU created (memberId == uid
        //     and you are settings.ownerUid). Unchanged.
        //
        //  3. Owner of THIS business — any role transition on any
        //     member doc (including their own demote / removal). The
        //     UI prevents the last-owner from demoting / removing
        //     themselves. A future server-side counter can add
        //     defense-in-depth.
        //
        //  4. Admin of THIS business — bounded transitions. They can
        //     write member docs only when:
        //       • The existing doc (if any) is NOT an owner, AND
        //       • The incoming role is NOT 'owner' (admin can't
        //         promote to owner).
        //     This rejects every owner-touching admin write.
        allow write: if isSignedIn() && (
          // ── Bootstrap & self-enroll paths (unchanged) ──
          request.auth.uid == businessId
          || (
            request.auth.uid == memberId
            && businessOwnerUid(businessId) == request.auth.uid
          )
          // ── Owner: any role transition. Last-owner protection is
          //    enforced client-side (a future hardening adds a
          //    denormalised ownerCount). ──
          || (
            memberDocExists(businessId)
            && memberRole(businessId) == 'owner'
          )
          // ── Admin: bounded transitions only. Cannot touch owner
          //    docs, cannot promote to owner, cannot write the
          //    per-member `permissions` override field.
          //
          //    P0 audit fix (2026-06-03): previously admins could
          //    write `permissions: {canManageOwners: true, ...}` on
          //    another member's doc. usePermissions() then trusted
          //    those booleans, granting effective owner powers
          //    without changing `role`. Block the field outright —
          //    role-based defaults from src/lib/permissions.ts are
          //    the canonical authority. Owners can still write the
          //    field via the owner branch above; their power is
          //    already unconstrained on this collection.
          || (
            memberDocExists(businessId)
            && memberRole(businessId) == 'admin'
            && (resource == null || resource.data.role != 'owner')
            && (
              request.method == 'delete'
              || (
                (request.resource.data.role == 'admin' || request.resource.data.role == 'technician')
                && !('permissions' in request.resource.data)
              )
            )
          )
          // ── Invite-based self-enroll. A signed-in user may CREATE
          //    their own member doc when the same atomic writeBatch
          //    has just transitioned an invite to status='accepted'
          //    for them. The member doc stamps the invite token so
          //    the rule can validate it against the post-batch
          //    state via getAfter().
          //
          //    Constraints (all must hold):
          //      • Writing your own doc (memberId == uid)
          //      • Creating (no existing doc — never an update path)
          //      • inviteToken field present on the payload
          //      • Invite exists, points at THIS business
          //      • Invite's recorded email matches the auth email
          //      • Invite status is 'accepted' AND acceptedByUid is
          //        the requesting user (which the same batch set)
          //      • Member role matches the invite's role
          //      • Role is admin | technician — never owner
          || (
            request.method == 'create'
            && request.auth.uid == memberId
            && request.resource.data.inviteToken is string
            && existsAfter(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken))
            && getAfter(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.businessId == businessId
            && getAfter(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.email == request.auth.token.email.lower()
            && getAfter(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.status == 'accepted'
            && getAfter(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.acceptedByUid == request.auth.uid
            && request.resource.data.role == getAfter(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.role
            && (request.resource.data.role == 'admin' || request.resource.data.role == 'technician')
            // P0 audit fix (2026-06-03): same `permissions` field
            // block as the admin branch above — a new joiner cannot
            // self-grant a custom permission map at acceptance time.
            && !('permissions' in request.resource.data)
          )
        );
      }

      // Meta collection — deletion requests and other admin signals.
      //
      // P0 audit fix (2026-06-03): the `deletion-request` doc triggers
      // a weekly scheduled Cloud Function (scheduledDeletionPurge) that
      // recursive-deletes the entire business subtree. Previously ANY
      // member of the business (including a technician) could write
      // this doc, enabling an insider-driven data-destruction primitive:
      // disgruntled tech writes the marker → 25 days later, the cron
      // hard-deletes the business's jobs, customers, inventory, etc.
      //
      // Two-layer fix:
      //   (a) Restrict write to owner/admin only.
      //   (b) For `deletion-request` specifically, require that
      //       `requestedBy` is the writing user — prevents an admin
      //       from spoofing the marker as the owner.
      // The Cloud Function adds a third check: re-verifies that the
      // marker's `requestedBy` matches the business's ownerUid before
      // calling recursiveDelete. See functions/src/scheduledDeletionPurge.ts.
      match /meta/{docId} {
        allow read: if isMemberOfBusiness(businessId);
        allow write: if isOwnerOrAdmin(businessId)
          && (
            docId != 'deletion-request'
            || request.resource.data.requestedBy == request.auth.uid
          );
      }

      // Bandilero — tenant-tunable intelligence config (thresholds /
      // windows). Any member can read so the module renders; only
      // owner/admin can tune. Absence is fine — the client falls back to
      // documented defaults (resolveConfig), never a fabricated value.
      match /bandilero/{docId} {
        allow read: if isMemberOfBusiness(businessId);
        allow write: if isOwnerOrAdmin(businessId);
      }

      // Presence collection — technician work status (Available /
      // En Route / On Site / Busy / Off Duty). Each user writes ONLY
      // their own presence doc; all members can read so the dispatch
      // board sees everyone's status. Deliberately separated from
      // members/{uid} so a tech's self-status update doesn't have
      // to go through the (much stricter) role-transition matrix.
      match /presence/{userId} {
        allow read:  if isMemberOfBusiness(businessId);
        allow write: if isSignedIn()
                       && request.auth.uid == userId
                       && isMemberOfBusiness(businessId);
      }

      // Everything else under the business (jobs, inventory, customers,
      // technicians, products) — any member can read. Writes default to
      // member-level too (technicians need to log jobs and consume
      // inventory mid-job). Sensitive paths above OVERRIDE this with
      // role-restricted writes via more-specific match blocks. Note:
      // Firestore rules union allow conditions across matching paths,
      // so this wildcard must NOT be more permissive than the specific
      // rules for sensitive collections. Since this rule only matches
      // documents NOT covered by the specific matches above when read
      // alone, but Firestore evaluates ALL matching rules, we keep
      // this aligned with the most-permissive intent for non-sensitive
      // paths only.
      //
      // To prevent the wildcard from re-enabling writes on sensitive
      // paths, the specific match blocks above use the same `read:
      // isMemberOfBusiness` for reads and restrict writes to
      // owner/admin. Because Firestore uses an OR across matching
      // rules, the wildcard write would still grant access to
      // settings/operational_settings/expenses/members. To prevent
      // this, we make the wildcard READ-only and let the per-path
      // rules above handle writes explicitly.
      match /{document=**} {
        allow read: if isMemberOfBusiness(businessId);
      }
      // Per-collection write rules for non-sensitive paths.
      // Jobs: role-based. Owner/admin full write; technician can
      // create jobs they own (createdByUid == self AND assignedToUid
      // == self), update jobs they're the assignee or creator of,
      // never delete. Legacy convention-owner (uid == businessId)
      // retains full write.
      match /jobs/{docId} {
        allow create: if isMemberOfBusiness(businessId) && (
          isOwnerOrAdmin(businessId) ||
          request.auth.uid == businessId ||
          (request.resource.data.createdByUid == request.auth.uid &&
           request.resource.data.assignedToUid == request.auth.uid)
        );
        allow update: if isMemberOfBusiness(businessId) && (
          isOwnerOrAdmin(businessId) ||
          request.auth.uid == businessId ||
          resource.data.assignedToUid == request.auth.uid ||
          resource.data.createdByUid == request.auth.uid
        );
        allow delete: if isOwnerOrAdmin(businessId) ||
                         request.auth.uid == businessId;
      }
      // Inventory: any member can update qty (the tire + mechanic
      // deduction paths issue inventory.update() at job-save time
      // and the batch must stay atomic). Catalog management
      // (create/delete) is restricted to owner/admin via the UI
      // permission flag canManageInventory; rules trust that gate.
      match /inventory/{docId} {
        allow create: if isOwnerOrAdmin(businessId) ||
                         request.auth.uid == businessId;
        allow update: if isMemberOfBusiness(businessId);
        allow delete: if isOwnerOrAdmin(businessId) ||
                         request.auth.uid == businessId;
      }
      // Customers + Vehicles (SP1): read access broadened to ALL
      // active members (owner/admin/technician) — intentional policy
      // change so technicians can browse the new Customers tab. Write
      // access is gated separately by two allowlists below.
      //
      // ─── Customers + Vehicles (SP1) ─────────────────────────────
      // Spec: docs/superpowers/specs/2026-06-03-customer-intelligence-design.md
      //       §"businesses/{businessId}/customers/{customerId}"
      //
      // INTENTIONAL ACCESS POLICY CHANGE (SP1): customers/{customerId}
      // read is now isMemberOfBusiness rather than owner/admin only.
      // Technicians need to browse the new top-level Customers tab.
      match /customers/{customerId} {
        allow read: if isMemberOfBusiness(businessId);

        // Meta-only writes (note, tags, Quick Notes, kind) — owner/admin only.
        // Quick Notes are operator-edited per refinement #2; same gate as note/tags.
        allow update: if isOwnerOrAdmin(businessId)
                     && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['note','tags','kind',
                                 'gateCode','apartmentNumber','wheelLockKeyLocation','tpmsNotes',
                                 'preferredPaymentMethod','parkingInstructions','preferredContactMethod','generalNotes',
                                 'deletedAt','updatedAt','lastEditedByUid','lastEditedAt']);

        // Identity upsert from saveJob — allowed for any active member
        // whose role canCreateJobs (owner/admin/technician). Split create
        // vs update because diff(resource.data) errors on null resource.
        allow create: if isMemberOfBusiness(businessId)
                     && memberRole(businessId) in ['owner','admin','technician']
                     && request.resource.data.keys()
                        .hasOnly(['name','nameLower','kind','companyName','companyLower',
                                 'phoneE164','phoneKey','email','addressLine',
                                 'city','cityLower','state','zipCode',
                                 'firstJobAt','lastJobAt','lastJobId',
                                 'jobCount','lifetimeRevenue','averageTicket',
                                 'customerStatus','vipTier','referralCount','photoCount',
                                 'lastContactedAt','createdByUid','createdAt','updatedAt',
                                 'processedJobIds','lastEditedByUid','lastEditedAt',
                                 'note','tags','gateCode','apartmentNumber','wheelLockKeyLocation','tpmsNotes',
                                 'preferredPaymentMethod','parkingInstructions','preferredContactMethod','generalNotes']);
        allow update: if isMemberOfBusiness(businessId)
                     && memberRole(businessId) in ['owner','admin','technician']
                     && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['name','nameLower','kind','companyName','companyLower',
                                 'phoneE164','phoneKey','email','addressLine',
                                 'city','cityLower','state','zipCode',
                                 'firstJobAt','lastJobAt','lastJobId',
                                 'jobCount','lifetimeRevenue','averageTicket',
                                 'customerStatus','vipTier','referralCount','photoCount',
                                 'lastContactedAt','createdByUid','createdAt','updatedAt',
                                 'processedJobIds','lastEditedByUid','lastEditedAt']);

        // Vehicles sub-collection — inherits parent read; writes allowed
        // for any active member with canCreateJobs (the upsert path).
        // Split create vs update because diff(resource.data) fails when
        // resource.data is null (the create case).
        match /vehicles/{vehicleId} {
          allow read: if isMemberOfBusiness(businessId);
          // `businessId` is the denormalized tenant id (2026-06-05
          // cross-tenant-leak fix). It must equal the path tenant so it
          // can't be spoofed to another business (which would expose the
          // doc to that tenant via the collection-group read rule).
          allow create: if isMemberOfBusiness(businessId)
                       && memberRole(businessId) in ['owner','admin','technician']
                       && request.resource.data.businessId == businessId
                       && request.resource.data.keys()
                          .hasOnly(['businessId',
                                   'year','make','model','trim','color',
                                   'makeModelLower','vehicleMakeModel','vehicleType','vehicleSize',
                                   'tireSize','alternateTireSize','tireBrand','tireCondition',
                                   'tpmsNotes','wheelLockNotes','serviceNotes',
                                   'lastServicedAt','lastServiceDate','lastJobId','serviceCount',
                                   'createdAt','updatedAt','processedJobIds']);
          allow update: if isMemberOfBusiness(businessId)
                       && memberRole(businessId) in ['owner','admin','technician']
                       && request.resource.data.businessId == businessId
                       && request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['businessId',
                                   'year','make','model','trim','color',
                                   'makeModelLower','vehicleMakeModel','vehicleType','vehicleSize',
                                   'tireSize','alternateTireSize','tireBrand','tireCondition',
                                   'tpmsNotes','wheelLockNotes','serviceNotes',
                                   'lastServicedAt','lastServiceDate','lastJobId','serviceCount',
                                   'createdAt','updatedAt','processedJobIds']);
          allow delete: if isOwnerOrAdmin(businessId);
        }
      }

      // ─── incomingCalls — Test Incoming Call admin write (SP6 dogfood) ───
      // Cloud Functions (SP4) bypass rules; this match block governs the
      // SP6 client-side Test Incoming Call admin action which writes a
      // synthetic ringing call. Allowed iff owner/admin AND provider == 'test'
      // AND createdAt within ~60s of server time (clock skew tolerance).
      // Real Twilio writes still come from Cloud Functions and bypass rules.
      match /incomingCalls/{callId} {
        allow read: if isMemberOfBusiness(businessId);
        allow create: if isOwnerOrAdmin(businessId)
                     && request.resource.data.provider == 'test'
                     && request.resource.data.createdAt is timestamp
                     && request.time - request.resource.data.createdAt < duration.value(60, 's');
        allow update: if isMemberOfBusiness(businessId)
                     && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['status','answeredByUid','callbackBookedJobId','customerId']);
        allow delete: if false;
      }

      // ─── incoming_calls — Phase 1 real-time screen-pop ──────────
      // Spec: docs/superpowers/specs/2026-06-05-incoming-call-screenpop-design.md
      //
      // Twilio voice-URL webhook (twilioIncomingCall Cloud Function)
      // writes docs here via the Admin SDK on every inbound ring
      // (DORMANT until operator activates SimRing). The component
      // subscribes to this collection and pops on doc arrival.
      //
      // Client access:
      //   - READ: any member of the business so every connected
      //           device pops on the ring.
      //   - WRITE: blocked. Only the Cloud Function writes via Admin
      //           SDK (which bypasses rules). Clients never enqueue
      //           ringing calls directly.
      //
      // Distinct from the SP6 `incomingCalls` collection (camelCase)
      // above, which governs the test-call admin write path. Phase 1
      // intentionally uses snake_case `incoming_calls` to keep the
      // two collections separate — different lifecycle (TTL ~60s here
      // vs operator-managed there) and different sources (Twilio
      // webhook here vs client admin write there).
      match /incoming_calls/{callId} {
        allow read:  if isMemberOfBusiness(businessId);
        allow write: if false;
      }

      // ─── reviewRequests — SP4A queue (admin SDK writes only) ─────
      // Cloud Functions enqueue + drain via admin SDK (bypasses rules).
      // Manual / test sends go through HTTPS callables, never client
      // writes. Reads gated to members of the business.
      match /reviewRequests/{requestId} {
        allow read:  if isMemberOfBusiness(businessId);
        allow write: if false;
      }

      // ─── communicationEvents — SP4A audit log (admin SDK only) ───
      // Trigger + drainer + callables log here. SP4B extends with
      // inbound call/SMS events. No client writes ever.
      match /communicationEvents/{eventId} {
        allow read:  if isMemberOfBusiness(businessId);
        allow write: if false;
      }

      // ─── leads — SP4B Lead queue (admin SDK writes only) ─────────
      // Webhook creates Leads via admin SDK (bypasses rules).
      // Clients may UPDATE workflow fields only — status/notes/etc.
      // Create + delete from client paths are blocked.
      match /leads/{leadId} {
        allow read:   if isMemberOfBusiness(businessId);
        allow create: if false;
        allow update: if isMemberOfBusiness(businessId)
                     && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['status','notes','assignedToUid','jobId',
                                  'closedAt','closedReason','updatedAt',
                                  'lastEditedByUid',
                                  // read state + lifecycle stage timestamps
                                  'viewedAt','contactedAt','quotedAt',
                                  'bookedAt','completedAt','lostAt']);
        allow delete: if false;
      }

      // ─── outboundSms — SP4B outbound queue (admin SDK only) ──────
      // Sibling to SP4A reviewRequests. Same access pattern.
      match /outboundSms/{smsId} {
        allow read:  if isMemberOfBusiness(businessId);
        allow write: if false;
      }

      // Technicians collection: legacy collection (Phase 1 stub);
      // restrict writes to owner/admin.
      match /technicians/{docId} {
        allow write: if isOwnerOrAdmin(businessId) ||
                        request.auth.uid == businessId;
      }
    }

    // ─────────────────────────────────────────────────────────────────
    // STRIPE FIREBASE EXTENSION COLLECTIONS
    //
    // The "Run Subscription Payments with Stripe" extension writes to
    // these top-level collections. The extension itself uses Admin SDK
    // and bypasses these rules — but the client app MUST be able to:
    //
    //   1. WRITE checkout_sessions and portal_links sub-docs (these are
    //      how the client requests a checkout URL — the extension reads
    //      these writes and fills in the URL).
    //   2. READ its own customer doc + subscriptions + payments + the
    //      checkout_session it just wrote (to receive the resolved URL).
    //   3. READ products + prices + tax_rates publicly (these are the
    //      catalog the client reads to display plan options if it ever
    //      needs to).
    //
    // Strict isolation: a user can only access their OWN /customers/{uid}
    // sub-tree (uid matches request.auth.uid). No cross-user reads.
    // ─────────────────────────────────────────────────────────────────

    match /customers/{uid} {
      // A user can read their own Stripe customer doc.
      allow read: if isSignedIn() && request.auth.uid == uid;
      // No client writes — Stripe extension creates this via Admin SDK.

      // Checkout sessions — scoped to the owning user only. The
      // Stripe Firebase Extension reads the session the CLIENT
      // writes and fills in the URL; any cross-user access would
      // let one signed-in user hijack another's checkout link.
      match /checkout_sessions/{id} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }

      match /subscriptions/{id} {
        // Read-only: the extension mirrors subscription state here.
        allow read: if isSignedIn() && request.auth.uid == uid;
        // No client writes.

        match /{path=**} {
          allow read: if isSignedIn() && request.auth.uid == uid;
        }
      }

      match /payments/{id} {
        // Read-only: extension writes invoice/payment history here.
        allow read: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // Stripe products + prices — public catalog read.
    // These are mirrored from Stripe by the extension. Any signed-in
    // user can read them so plan selection UIs render.
    match /products/{productId} {
      allow read: if isSignedIn();
      match /prices/{priceId} {
        allow read: if isSignedIn();
      }
      match /tax_rates/{taxRateId} {
        allow read: if isSignedIn();
      }
    }

    // (The PayPal Zettle integration was removed. Its top-level
    // collections — zettleOrgs and zettleSecure/{businessId}/... — no
    // longer have rules, so they default-deny. Any orphaned historical
    // docs are inert and unreadable.)

    // ─────────────────────────────────────────────────────────────────
    // REFERRAL SYSTEM
    //
    // Top-level collections:
    //
    //   /referralCodes/{CODE} — side-index mapping code → businessId.
    //     Each business has exactly one entry. The client creates it
    //     during onboarding when calling ensureReferralCode(). After
    //     that, the doc is immutable from the client.
    //
    //   /referrals/{id} — one doc per referral signup. Lifecycle is
    //     server-driven by the Cloud Function listening to Stripe
    //     subscription events. The client can CREATE only the initial
    //     `pending` state (during signup, when a new business has just
    //     been referred). All status transitions happen server-side.
    //
    // Reading: a business can read referrals where it is either the
    // referrer or the referred party. No cross-business prying.
    // ─────────────────────────────────────────────────────────────────

    match /referralCodes/{code} {
      // Anyone signed in can READ a code's target businessId — needed
      // to validate a `?ref=CODE` URL param during signup. Codes are
      // not secrets; the link itself is meant to be shared.
      allow read: if isSignedIn();
      // CREATE: signed-in user can claim a code if it doesn't already
      // exist (Firestore's create-only check) AND the businessId
      // matches their own.
      //
      // P1 audit fix (2026-06-03): added format enforcement. The
      // previous rule let users claim arbitrary strings as referral
      // codes — `/admin`, `/google`, profanity, dictionary squats.
      // Constrain to 6-12 uppercase alphanumerics, matching the
      // generator's output in src/lib/inviteUtils.ts.
      allow create: if isSignedIn()
        && request.resource.data.businessId == request.auth.uid
        && code.matches('^[A-Z0-9]{6,12}$');
      // No updates or deletes from clients. Codes are immutable once
      // claimed. Admin SDK handles edge cases (e.g. revocation).
      allow update, delete: if false;
    }

    match /referrals/{refId} {
      // READ: a business can see referrals where they're the referrer
      // OR the referred party. Both sides legitimately want visibility.
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.referrerBusinessId
        || request.auth.uid == resource.data.referredBusinessId
        || request.auth.uid == resource.data.referredUid
      );
      // CREATE: signed-in user can create a referral doc only when:
      //   1. They are the referred party (the new signup)
      //   2. Status is 'pending' (cannot pre-set to 'rewarded')
      //   3. No reward fields are populated (those come from server)
      //   4. The referrer is NOT themselves (no self-referrals)
      allow create: if isSignedIn()
        && request.resource.data.referredUid == request.auth.uid
        && request.resource.data.referredBusinessId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.referrerBusinessId != request.auth.uid
        && !('rewardedAt' in request.resource.data)
        && !('stripeBalanceTransactionId' in request.resource.data)
        && !('creditAmountUsd' in request.resource.data);
      // No client updates or deletes. All transitions through Admin SDK.
      allow update, delete: if false;
    }

    // SP3: collection-group vehicles read — GlobalSearchSheet uses
    // collectionGroup(db, 'vehicles') for the makeModelLower / plate
    // / tireSize prefix branches. Scoping is enforced server-side here:
    // the requester must be a member of the vehicle's own business
    // (denormalized onto the doc as `businessId` by _buildVehiclePatch).
    // The searchCustomers queries always constrain `where('businessId','==',bid)`
    // to match. (2026-06-05 security audit: previously `request.auth != null`
    // alone, which let any signed-in user read every tenant's vehicles.)
    match /{path=**}/vehicles/{vehicleId} {
      allow read: if isMemberOfBusiness(resource.data.businessId);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
